# ---------------------------------------------------------------------------
# CLIENT (browser) — must be VITE_-prefixed to be exposed to the front end.
# Until both are set, useProducts() falls back to src/data/products.json.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-publishable-key

# ---------------------------------------------------------------------------
# Firebase Auth — customer phone OTP + Google login (src/lib/firebase.js).
# From Firebase Console -> Project settings -> General -> Your apps -> SDK
# setup and configuration -> Config.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ---------------------------------------------------------------------------
# SERVER ONLY — used by the Vercel serverless functions in /api.
# NO VITE_ prefix: these must NEVER reach the browser.
#   - SUPABASE_SERVICE_ROLE_KEY bypasses RLS (full DB access).
#   - RAZORPAY_KEY_SECRET signs/verifies payments.
# Set these in `.env` for `vercel dev`, and in the Vercel dashboard for deploys.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Razorpay — use TEST MODE keys while developing (rzp_test_...).
# RAZORPAY_KEY_ID is public (the server returns it to the browser to open
# Checkout); RAZORPAY_KEY_SECRET is private and stays on the server.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Razorpay webhook secret — set the SAME value here and in the Razorpay
# dashboard (Settings → Webhooks). Lets /api/razorpay-webhook confirm payments
# server-side even if the customer's browser never returns after paying.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ---------------------------------------------------------------------------
# OPTIONAL — customer status emails (admin sets an order to shipped/delivered).
# Without these the update still works; the email is just skipped.
#   1. Create a Resend account, verify your sending domain.
#   2. RESEND_API_KEY  — from the Resend dashboard.
#   3. MAIL_FROM       — a verified from-address, e.g. "MetTel <orders@mettel.in>".
#   4. SITE_URL        — used for the "track" link in the email (optional).
# ---------------------------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM=MetTel <orders@mettel.in>
SITE_URL=https://www.mettel.in
